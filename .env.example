# ============================================================
# Grep vs RAG 实验配置文件
# 复制此文件为 .env 并填入你的真实配置
#   cp .env.example .env
# ============================================================

# ── API Keys（必填）────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# ── API Base URL（留空=官方默认，填自定义=代理/第三方）─────
# 例: ANTHROPIC_BASE_URL=https://api.your-proxy.com
ANTHROPIC_BASE_URL=
# 例: OPENAI_BASE_URL=https://api.your-proxy.com/v1
OPENAI_BASE_URL=

# ── LLM 模型选择 ───────────────────────────────────────────
# Anthropic: claude-sonnet-4-6, claude-opus-4-8 等
ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenAI: gpt-4o, gpt-4o-mini 等
OPENAI_MODEL=gpt-4o

# ── Embedding 模型 ─────────────────────────────────────────
# 本地模型 (默认 BGE，免费，首次运行自动下载 ~100MB)
EMBEDDING_MODEL=BAAI/bge-small-zh
# 运行设备: cpu 或 cuda
EMBEDDING_DEVICE=cpu

# ── 检索参数 ───────────────────────────────────────────────
# RAG 每次返回的 top-k 文本块
VECTOR_TOP_K=5
# 文本分块大小（字符数）
CHUNK_SIZE=300
# 分块重叠量（字符数）
CHUNK_OVERLAP=50
# grep 匹配行前后各展示行数
GREP_CONTEXT_LINES=1

# ── Agent 参数 ─────────────────────────────────────────────
# 最多搜索轮次（超过后强制结束）
MAX_AGENT_TURNS=8
# 推理温度（越低越确定性）
AGENT_TEMPERATURE=0.1
# 单次 API 调用超时秒数
AGENT_TIMEOUT=120

# ── 实验矩阵 ───────────────────────────────────────────────
# 数据集大小: small,medium,large（逗号分隔，如 small,medium）
DATASET_SIZES=small
# 检索模式: grep,vector（逗号分隔）
TOOL_MODES=grep,vector
# LLM Backend: anthropic,openai（逗号分隔）
BACKENDS=anthropic,openai

# ── 运行控制 ───────────────────────────────────────────────
# 限制题目数量（调试用，填数字或留空=全部）
LIMIT_QUESTIONS=
# API 调用失败重试次数
RETRY_COUNT=3
