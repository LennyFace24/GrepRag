# ============================================================
# Grep vs RAG 实验配置文件
#   cp .env.example .env  然后填入你的配置
# ============================================================

# ── CLI Agent ──────────────────────────────────────────────
# 实验后端: claude,codex（逗号分隔，可选一个或多个）
BACKENDS=claude,codex

# CLI 使用的模型（留空=用 CLI 默认配置）
CLAUDE_CLI_MODEL=
CODEX_CLI_MODEL=

# CLI 超时（秒）
CLI_AGENT_TIMEOUT=300
# 推理温度（越低越确定性）
CLI_TEMPERATURE=0.1

# ── 速率控制 / 反风控 ──────────────────────────────────────
# 每次请求前随机延迟范围（秒）
RATE_LIMIT_DELAY_MIN=0.5
RATE_LIMIT_DELAY_MAX=2.0
# 触发 429 后的基础等待秒数（会指数退避: ×1, ×2, ×4）
RATE_LIMIT_BACKOFF=5
RATE_LIMIT_MAX_RETRIES=3

# ── Embedding（vector 检索使用）────────────────────────────
# 提供者: bge(本地免费) 或 qwen(API)
EMBED_PROVIDER=bge
# BGE 本地模型 (EMBED_PROVIDER=bge 时生效)
EMBEDDING_MODEL=BAAI/bge-small-zh
EMBEDDING_DEVICE=cpu
# Qwen API (EMBED_PROVIDER=qwen 时生效)
QWEN_EMBED_ENDPOINT=https://ai.gitee.com/v1
QWEN_EMBED_KEY=
QWEN_EMBED_MODEL=qwen3-embedding-8b

# ── 检索参数 ───────────────────────────────────────────────
VECTOR_TOP_K=5
CHUNK_SIZE=300
CHUNK_OVERLAP=50

# ── 实验矩阵 ───────────────────────────────────────────────
DATASET_SIZES=small
TOOL_MODES=grep,vector

# ── 运行控制 ───────────────────────────────────────────────
LIMIT_QUESTIONS=          # 留空=全部, 填数字=只跑前N题
MAX_WORKERS=1             # 1=顺序, 4=4并发
RETRY_COUNT=3
